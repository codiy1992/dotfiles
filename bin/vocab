#!/usr/bin/env bash

# set -ex

OS_TYPE=$(uname)
deck="English"
model="Vocabulary"
query=""
field=""
value=""
tags=""

declare -A FIELDS

FIELDS["w"]="Word"
FIELDS["p"]="Pictures"
FIELDS["t"]="Transcriptions"
FIELDS["n"]="Notes"
FIELDS["d"]="Definitions"
FIELDS["e"]="Examples"

if [[ $# < 1 ]] || [[ $# > 3 ]]; then
    echo -e "\033[49;31mWrong parameters.\033[0m"; exit 1;
fi

if [[ $# == 1 ]]; then
    field="Word"
    value="$1"
fi

if [[ $# == 2 ]]; then
    query="deck:$deck Word:$1"
    field="${FIELDS[$2]-$2}"
    if [[ "$field" == "Pictures" ]]; then
        value=$(imgup anki/english/vocab "$1-$(date +'%Y%m%d%H%M%S').png")
        value="<img src='$value' />"
    else
        [[ "${OS_TYPE}" == "Darwin" ]] && {
            value="$(pbpaste)"
        }
    fi
fi

if [[ $# == 3 ]]; then
    query="deck:$deck Word:$1"
    field="$2"
    value="$3"
fi

{
    acla -deck $deck -model $model -query "$query" -field $field -value "$value" -tags "$tags"

    if [[ "$field" == "Word" ]]; then
        acla -deck $deck -query "deck:$deck Word:$value" -field Text -value "{{c1::$value}}"
    fi
} &
